# ─── API ──────────────────────────────────────────────────────────────────────
VITE_API_URL=https://YOUR_CLOUD_RUN_URL

# ─── Firebase (from Firebase Console → Project Settings → Your App) ───────────
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ─── Stripe Payment Links (from Stripe Dashboard → Payment Links) ─────────────
VITE_STRIPE_MONTHLY_LINK=https://buy.stripe.com/YOUR_MONTHLY_LINK
VITE_STRIPE_ANNUAL_LINK=https://buy.stripe.com/YOUR_ANNUAL_LINK
